@model IEnumerable<DoAn.Models.Registration>

@{
    ViewData["Title"] = "Lịch sử điểm danh";
}

<div class="card shadow border-0">
    <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
        <h5 class="mb-0 fw-bold text-primary">Lịch sử điểm danh</h5>
        <a asp-action="Scan" class="btn btn-primary btn-sm rounded-pill px-3">
            <i class="fas fa-qrcode me-1"></i>Về trang quét mã
        </a>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Người tham dự</th>
                        <th>Sự kiện</th>
                        <th>Địa điểm</th>
                        <th>Thời gian điểm danh</th>
                        <th>Trạng thái</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <div class="fw-bold">@item.User?.FullName</div>
                                <div class="small text-muted">@item.User?.Email</div>
                            </td>
                            <td>@item.Event?.Title</td>
                            <td>@item.Event?.Location</td>
                            <td>@item.CheckInTime?.ToString("HH:mm dd/MM/yyyy")</td>
                            <td>
                                <span class="badge bg-success rounded-pill px-3">Thành công</span>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-4 text-muted">
                                Chưa có dữ liệu điểm danh nào.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
