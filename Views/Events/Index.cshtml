@model IEnumerable<DoAn.Models.Event>

@{
    ViewData["Title"] = "Danh sách sự kiện";
}

<div class="d-flex justify-content-between align-items-center mb-5">
    <div>
        <h1 class="h2 fw-bold text-dark mb-1">@(User.IsInRole("Admin") ? "Quản lý sự kiện" : "Sự kiện sắp tới")</h1>
        <p class="text-muted mb-0">Khám phá và tham gia các sự kiện hấp dẫn nhất.</p>
    </div>
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm">
            <i class="fas fa-plus me-2"></i> TẠO SỰ KIỆN MỚI
        </a>
    }
</div>

<div class="row g-4">
    @foreach (var item in Model)
    {
        <div class="col-xl-4 col-md-6">
            <div class="card h-100 shadow-sm border-0 rounded-4 overflow-hidden position-relative">
                @if (!string.IsNullOrEmpty(item.ImageUrl))
                {
                    <img src="@item.ImageUrl" class="card-img-top" alt="@item.Title" style="height: 220px; object-fit: cover;">
                }
                else
                {
                    <div class="bg-primary text-white d-flex align-items-center justify-content-center" style="height: 220px;">
                        <i class="fas fa-calendar-alt fa-5x opacity-50"></i>
                    </div>
                }
                
                <div class="card-body p-4">
                    <h5 class="card-title fw-bold text-primary mb-3">@item.Title</h5>
                    <div class="small text-muted mb-2">
                        <i class="fas fa-map-marker-alt text-danger me-2"></i> @item.Location
                    </div>
                    <div class="small text-muted mb-3">
                        <i class="fas fa-calendar-check text-info me-2"></i> @item.StartTime.ToString("HH:mm, dd/MM/yyyy")
                    </div>
                    <p class="card-text text-muted small text-truncate-2 mb-0">@item.Description</p>
                </div>

                <div class="card-footer bg-white border-top-0 p-4 pt-0">
                    <hr class="mt-0 mb-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm rounded-pill px-3 fw-bold">Xem chi tiết</a>
                        
                        @if (User.IsInRole("Admin"))
                        {
                            <div class="d-flex gap-2">
                                <a asp-action="Registrants" asp-route-id="@item.Id" class="btn btn-light btn-sm rounded-pill px-3 fw-bold border text-primary" title="Danh sách đăng ký">
                                    <i class="fas fa-users me-1"></i> @item.Registrations.Count
                                </a>
                                <div class="dropdown">
                                    <button class="btn btn-light btn-sm rounded-circle border shadow-sm" data-bs-toggle="dropdown">
                                        <i class="fas fa-ellipsis-v"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                                        <li><a class="dropdown-item text-warning" asp-action="Edit" asp-route-id="@item.Id"><i class="fas fa-edit me-2"></i>Chỉnh sửa</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item text-danger" asp-action="Delete" asp-route-id="@item.Id"><i class="fas fa-trash me-2"></i>Xóa sự kiện</a></li>
                                    </ul>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .text-truncate-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>
