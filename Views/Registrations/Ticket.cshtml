@model DoAn.Models.Registration

@{
    ViewData["Title"] = "Vé sự kiện - " + Model.Event?.Title;
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <div class="bg-primary text-white text-center py-4">
                    <h3 class="mb-0 fw-bold">VÉ THAM DỰ SỰ KIỆN</h3>
                </div>
                <div class="card-body p-0">
                    <div class="p-4 text-center border-bottom bg-light">
                        <img src="data:image/png;base64,@ViewBag.QrCodeImage" alt="QR Code" class="img-fluid shadow-sm rounded-3 mb-3" style="width: 200px;">
                        <p class="text-muted small mb-0">Mã: @Model.CheckInCode</p>
                        <p class="mt-2 text-primary fw-bold">Dùng mã này để điểm danh tại sự kiện</p>
                    </div>
                    
                    <div class="p-4">
                        <div class="mb-4">
                            <h4 class="text-primary fw-bold">@Model.Event?.Title</h4>
                            <div class="d-flex align-items-center mt-3 mb-2">
                                <i class="fas fa-map-marker-alt text-danger me-3 fa-fw"></i>
                                <div>
                                    <div class="fw-bold">Địa điểm</div>
                                    <div class="text-muted">@Model.Event?.Location</div>
                                </div>
                            </div>
                            <div class="d-flex align-items-center mb-2">
                                <i class="fas fa-clock text-info me-3 fa-fw"></i>
                                <div>
                                    <div class="fw-bold">Thời gian</div>
                                    <div class="text-muted">@Model.Event?.StartTime.ToString("dd/MM/yyyy HH:mm")</div>
                                </div>
                            </div>
                            <div class="d-flex align-items-center">
                                <i class="fas fa-user text-secondary me-3 fa-fw"></i>
                                <div>
                                    <div class="fw-bold">Người tham dự</div>
                                    <div class="text-muted">@User.Identity?.Name</div>
                                </div>
                            </div>
                        </div>
                        
                        @if (Model.IsCheckedIn)
                        {
                            <div class="alert alert-success d-flex align-items-center border-0 rounded-3 shadow-sm mb-0">
                                <i class="fas fa-check-circle fa-2x me-3"></i>
                                <div>
                                    <div class="fw-bold">Đã điểm danh thành công!</div>
                                    <div class="small">Lúc: @Model.CheckInTime?.ToString("HH:mm dd/MM/yyyy")</div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
                <div class="card-footer bg-white border-top-0 p-4 text-center">
                    <button onclick="window.print()" class="btn btn-outline-secondary px-4 rounded-pill">
                        <i class="fas fa-print me-2"></i>In vé tham dự
                    </button>
                    <a asp-action="MyTickets" class="btn btn-primary px-4 rounded-pill ms-2">
                        Quay lại danh sách
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    @@media print {
        header, footer, .btn, .breadcrumb {
            display: none !important;
        }
        .container {
            margin: 0 !important;
            padding: 0 !important;
            max-width: 100% !important;
        }
        .card {
            box-shadow: none !important;
            border: 1px solid #dee2e6 !important;
        }
    }
</style>
